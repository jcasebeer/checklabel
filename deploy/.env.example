# Copy to deploy/.env on the server. Never commit the real file.

# Required — model access
ANTHROPIC_API_KEY=sk-ant-...

# Required — token of the Cloudflare Tunnel connector
# (Zero Trust dashboard -> Networks -> Tunnels -> your tunnel -> token)
TUNNEL_TOKEN=eyJ...

# Optional app overrides (defaults shown; see app/config.py)
# LABEL_CHECK_MODEL=claude-sonnet-4-6
# LABEL_CHECK_BATCH_CONCURRENCY=8
# LABEL_CHECK_ABV_TOLERANCE=0.0
# LABEL_CHECK_BRAND_WARN=0.90
# LABEL_CHECK_MAX_IMAGES_PER_LABEL=8

# Access control (both optional):
# API key for the /batch endpoints; callers send "Authorization: Bearer <key>"
# or "X-API-Key: <key>". Unset = open (demo posture — the spend cap below is
# what protects the budget).
# LABEL_CHECK_API_KEY=
# Cap on estimated model spend (USD) per visitor network per rolling 24h.
# IPv4 = per address; IPv6 = per provider /32. 0 disables.
# LABEL_CHECK_SPEND_CAP_PER_IP=2.0
